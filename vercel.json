{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/check/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/robots.txt",
      "dest": "frontend/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "frontend/sitemap.xml"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}