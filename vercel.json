{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/check/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/robots.txt",
      "dest": "frontend/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "frontend/sitemap.xml"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}